SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
FLASK_ENV=development
PRELOAD_MODELS=1
PRELOAD_POLARITY_MODEL=0
PRELOAD_VISION_MODEL=0
HF_LOCAL_FILES_ONLY=0
PRELOAD_ONLY_CACHED_MODELS=1


# Social media API keys
TWITTER_BEARER_TOKEN=replace-with-twitter-bearer-token
INSTAGRAM_ACCESS_TOKEN=replace-with-instagram-access-token

# Optional database override
# DATABASE_URL=sqlite:///xsense.db
